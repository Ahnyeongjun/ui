{
  "name": "@nuguri03/tokens",
  "version": "0.1.0",
  "description": "Design tokens for nuguri03 portfolio",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
